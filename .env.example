# Multiplayer (Supabase Realtime) — optional.
# Copy this file to ".env" and paste your project's values.
# Both are PUBLIC client values (safe in a static site). The site works
# fine without them — multiplayer just stays dormant.
#
# Get them in Supabase: Project Settings -> API
#   Project URL  -> VITE_SUPABASE_URL
#   anon public  -> VITE_SUPABASE_ANON_KEY

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
